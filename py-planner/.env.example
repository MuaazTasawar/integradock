# Server
PORT=8000
ENV=development

# Go engine
GO_ENGINE_URL=http://localhost:8080
INTERNAL_API_SECRET=REPLACE_WITH_RANDOM_SECRET_STRING

# LLM providers (set at least one)
ANTHROPIC_API_KEY=REPLACE_WITH_YOUR_ANTHROPIC_KEY
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_KEY
DEFAULT_LLM_PROVIDER=anthropic

# Stripe test mode (for demo tool)
STRIPE_TEST_SECRET_KEY=REPLACE_WITH_STRIPE_TEST_SK